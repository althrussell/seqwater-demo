# Generated synthetic data (regenerate via scripts/generate_synthetic_data.py)
data/synthetic/*.csv
data/synthetic/*.parquet
data/synthetic/*.json
!data/synthetic/.gitkeep

# Generated synthetic PDFs (regenerate via scripts/generate_synthetic_pdfs.py)
data/documents/pdf/

# TS / Vite build artefacts
frontend/.tsbuildinfo*
frontend/tsconfig*.tsbuildinfo
frontend/.tsnode/
frontend/vite.config.d.ts
frontend/vite.config.js

# Logs
logs/
*.log

# Databricks
.databricks/

# Generated app spec (rendered from databricks/app_create.template.json by scripts/deploy_app.py)
databricks/app_create.json

# NOTE: app.yaml is rendered from app.template.yaml by scripts/deploy_app.py at deploy
# time. It is intentionally NOT gitignored — `databricks sync` skips gitignored files,
# and the Apps runtime requires app.yaml to be present in the synced source path.
# Re-running scripts/deploy_app.py refreshes it from the template.
