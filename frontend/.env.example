# Mapbox configuration for the SEQ Water Grid Map.
# Required. Get a public token from https://account.mapbox.com/access-tokens/
VITE_MAPBOX_TOKEN=pk.your-token-here

# Optional. Defaults to satellite-streets when omitted.
# Suggested alternatives:
#   mapbox://styles/mapbox/light-v11
#   mapbox://styles/mapbox/outdoors-v12
#   mapbox://styles/mapbox/standard
VITE_MAPBOX_STYLE=mapbox://styles/mapbox/satellite-streets-v12
