# Seqwater AI Command Centre — Environment Variables
# Copy to .env and customise for your environment.

# ---------- Mode ----------
# "local"      = run end-to-end with data and mock AI (default, no Databricks needed)
# "databricks" = use serverless SQL Warehouse + Foundation Model API + Volumes + UC
APP_MODE=local

# ---------- Databricks workspace ----------
# Use either a CLI profile (recommended) OR a host + token combination.
# When running inside a Databricks App, host + OAuth M2M creds are auto-injected.
DATABRICKS_CONFIG_PROFILE=DEFAULT
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
DATABRICKS_TOKEN=
DATABRICKS_WAREHOUSE_ID=
DATABRICKS_CATALOG=main
DATABRICKS_SCHEMA=seqwater_demo
DATABRICKS_VOLUME=operational_docs

# ---------- Foundation Model API ----------
# Examples: databricks-meta-llama-3-3-70b-instruct, databricks-claude-sonnet-4,
#           databricks-gpt-oss-120b, databricks-gpt-5-5
DATABRICKS_LLM_ENDPOINT=databricks-gpt-oss-120b
DATABRICKS_LLM_TEMPERATURE=0.1
DATABRICKS_LLM_MAX_TOKENS=2048

# ---------- Vector Search (optional) ----------
DATABRICKS_VECTOR_SEARCH_ENDPOINT=
DATABRICKS_VECTOR_SEARCH_INDEX=

# ---------- Agent Bricks ----------
# Populated by `python scripts/setup_agent_bricks.py`.
# When DATABRICKS_SUPERVISOR_ENDPOINT is set in databricks mode, the AquaIQ
# agent routes through the Supervisor (which orchestrates KA + Genie + UC fns).
# Otherwise it falls back to the deterministic local-mode tool path.
DATABRICKS_SUPERVISOR_ENDPOINT=
DATABRICKS_SUPERVISOR_TILE_ID=
DATABRICKS_KA_ENDPOINT=
DATABRICKS_KA_TILE_ID=
DATABRICKS_GENIE_SPACE_ID=

# ---------- Genie embed (optional) ----------
# Iframe URL for the embedded Genie Space, exposed at /genie in the UI.
# Recommended: paste the URL generated by Genie → Share → Embed space.
# Fallback: leave empty and the app will try {DATABRICKS_HOST}/embed/genie/{DATABRICKS_GENIE_SPACE_ID}.
# Pre-reqs (workspace admin):
#   1. Enable the "Embed Genie as an iframe" preview.
#   2. Add the App's deployed origin to allowed embedding surfaces.
# Docs: https://docs.databricks.com/aws/en/genie/embed
DATABRICKS_GENIE_EMBED_URL=

# ---------- App ----------
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_DEV_PORT=5173
SYNTHETIC_DATA_DIR=data/synthetic
DOCUMENTS_DIR=data/documents

# ---------- MLflow tracing (optional) ----------
MLFLOW_TRACKING_URI=
MLFLOW_EXPERIMENT_NAME=/Shared/seqwater-aquaiq

# ---------- Demo controls ----------
DEMO_SEED=20260529
DEMO_TIMEZONE=Australia/Brisbane
